# Local model server endpoint for set planning
LOCAL_MODEL_ENDPOINT=http://127.0.0.1:8080

# Local model name (default: Qwen/Qwen3-8B-Instruct)
LOCAL_MODEL_NAME=Qwen/Qwen3-8B-Instruct

# Optional auth token for local model server
LOCAL_MODEL_TOKEN=

# Spotify API credentials (for track discovery)
SPOTIFY_CLIENT_ID=your-client-id
SPOTIFY_CLIENT_SECRET=your-client-secret

# Database path (default: data/deepcrate.sqlite)
DATABASE_PATH=data/deepcrate.sqlite
